  {
    "name": "AdditionalInformation",
    "title": "Additional Information",
    "getApi": "/api/additional/get",
    "saveApi": "/api/additional/save",
    "fields": [
      {
        "name": "whatsappNumber",
        "label": "WhatsApp Number*",
        "placeholder": "+91 98765 43210",
        "type": "tel",
        "required": true
      },
      {
        "name": "dateOfBirth",
        "label": "Date of Birth*",
        "type": "date",
        "required": true
      },
      {
        "name": "futureSubjectArea",
        "label": "Which subject area do you want to pursue in future?*",
        "placeholder": "Select subject area",
        "type": "select",
        "options": [
          "Computer Science & Engineering",
          "Data Science & Artificial Intelligence",
          "Electronics & Communication",
          "Mechanical Engineering",
          "Civil Engineering",
          "Electrical Engineering",
          "Biotechnology",
          "Business / Management",
          "Medicine / Healthcare",
          "Law",
          "Design / Creative Arts",
          "Agriculture",
          "Others"
        ],
        "required": true
      },
      {
        "name": "futureSubField",
        "label": "Which sub-field do you want to pursue in it?*",
        "placeholder": "Select sub-field",
        "type": "select",
        "dependsOn": "futureSubjectArea",
        "options": {
          "Computer Science & Engineering": [
            "Software Development",
            "Web Development",
            "Mobile App Development",
            "Cybersecurity",
            "Cloud Computing",
            "Blockchain",
            "Game Development",
            "Others"
          ],
          "Data Science & Artificial Intelligence": [
            "Machine Learning",
            "Deep Learning",
            "Natural Language Processing",
            "Computer Vision",
            "Big Data Analytics",
            "Data Engineering",
            "Others"
          ],
          "Electronics & Communication": [
            "VLSI Design",
            "Embedded Systems",
            "IoT",
            "Robotics",
            "Signal Processing",
            "Others"
          ],
          "Mechanical Engineering": [
            "Automobile Engineering",
            "Thermal Engineering",
            "Manufacturing",
            "CAD/CAM",
            "Robotics & Automation",
            "Others"
          ],
          "Others": ["Others"]
        },
        "customOption": true,
        "customFieldName": "customSubField",
        "required": true
      },
      {
        "name": "whyApply",
        "label": "Why are you applying for this program?*",
        "placeholder": "Tell us why you want to join this program...",
        "type": "textarea",
        "rows": 3,
        "required": true
      },
      {
        "name": "challenges",
        "label": "What challenges do you face in your studies and career?*",
        "placeholder": "What difficulties are you facing in studies or career...",
        "type": "textarea",
        "rows": 3,
        "required": true
      },
      {
        "name": "inspiringProfessorName",
        "label": "Inspiring Professor Name",
        "placeholder": "Name of the professor who inspired you",
        "type": "text",
        "required": false
      },
      {
        "name": "professorContactNumber",
        "label": "Professor's Contact Number",
        "placeholder": "Professor's contact number",
        "type": "tel",
        "required": false
      },
      {
        "name": "partnerOrganization",
        "label": "Partner Organization*",
        "helper": "If none, please select \"I'm applying on my own\"",
        "placeholder": "Select partner organization",
        "type": "select",
        "options": [
          "Dr. Reddy's Foundation",
          "Tata Trusts",
          "Infosys Foundation",
          "I'm applying on my own"
        ],
        "required": true
      }
    ],
